# SORSABSA - PeritoDigital (Agente IA)
# Copiar este archivo a .env y completar los valores reales

# --- INFRAESTRUCTURA ---
PORT=8001
DEBUG=True
ENVIRONMENT=development

# --- IA (Anthropic) ---
ANTHROPIC_API_KEY=your-sk-ant-key

# --- WHATSAPP (Whapi.cloud) ---
WHAPI_API_URL=https://gate.whapi.cloud
WHAPI_TOKEN=your-whapi-token

# --- SUPABASE (SORSABSA v2.0) ---
# Mantenemos el esquema sorsabsa_identity para persistencia de sesiones
DATABASE_URL=postgresql://postgres:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?options=-c%20search_path%3Dsorsabsa_identity

# --- CONFIGURACIÓN ANTI-BLOQUEO ---
# Tiempo máximo de espera para la respuesta de la IA (segundos)
AI_TIMEOUT=8.0
# ID del canal para logs de emergencia
LOG_CHANNEL_ID=your-id
SUPABASE_URL=https://tkkpqbelzwoenmeynjvw.supabase.co